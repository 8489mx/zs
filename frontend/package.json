{
  "name": "zsystems-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run repair:permissions && vite",
    "build": "npm run repair:permissions && node ./node_modules/typescript/lib/tsc.js -b && node ./node_modules/vite/bin/vite.js build",
    "preview": "vite preview",
    "qa:routes": "node scripts/route-qa.mjs",
    "qa:features": "node scripts/feature-structure-check.mjs && node scripts/feature-boundary-check.mjs",
    "qa": "npm run lint && npm run qa:functional && npm run qa:api && npm run qa:routes && npm run qa:architecture && npm run qa:tests && npm run build",
    "qa:functional": "node scripts/functional-smoke.mjs && node scripts/feature-route-map.mjs",
    "qa:composition": "node scripts/page-composition-check.mjs && node scripts/feature-contract-check.mjs",
    "qa:api": "node scripts/api-contract-alignment.mjs && node scripts/api-envelope-check.mjs",
    "qa:decoupling": "node scripts/feature-api-decoupling-check.mjs",
    "qa:critical": "node scripts/critical-flow-check.mjs",
    "qa:route-live": "node scripts/route-live-sweep.mjs",
    "qa:guards": "node scripts/route-guard-check.mjs",
    "qa:live-flows": "node scripts/purchase-inventory-live-flow-check.mjs",
    "qa:split": "node scripts/code-splitting-check.mjs",
    "qa:rc": "node scripts/release-candidate-check.mjs",
    "qa:contracts": "node scripts/api-mutation-envelope-check.mjs",
    "qa:release": "node scripts/release-audit.mjs",
    "qa:commercial-ready": "npm run qa:guards && npm run qa:critical && npm run qa:rc && npm run qa:release",
    "repair:permissions": "node scripts/fix-binary-permissions.cjs",
    "qa:phase23": "node scripts/release-candidate-check.mjs",
    "qa:phase57": "node scripts/run-phase60-qa.mjs",
    "qa:phase58": "node scripts/run-phase60-qa.mjs",
    "qa:phase59": "node scripts/run-phase60-qa.mjs",
    "qa:phase60": "node scripts/run-phase60-qa.mjs",
    "lint": "node ./node_modules/eslint/bin/eslint.js .",
    "lint:fix": "node ./node_modules/eslint/bin/eslint.js . --fix",
    "qa:architecture": "node scripts/feature-structure-check.mjs && node scripts/feature-boundary-check.mjs && node scripts/import-layer-check.mjs && node scripts/dev-proxy-check.mjs && node scripts/password-policy-sync-check.mjs && node scripts/auth-setup-hardening-check.mjs && node scripts/auth-ui-test-coverage-check.mjs",
    "qa:uat": "npm run qa:guards && npm run qa:critical && npm run qa:release",
    "test": "npm run test:run",
    "test:run": "node ./node_modules/vitest/vitest.mjs run",
    "test:watch": "node ./node_modules/vitest/vitest.mjs",
    "qa:tests": "npm run test:run",
    "qa:preprod-ui": "npm run lint && npm run test:run && npm run build"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.90.5",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.66.0",
    "react-router-dom": "^7.9.4",
    "zod": "^4.1.11",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.6.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^7.1.12",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=22 <23"
  }
}
