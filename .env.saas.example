APP_MODE=CLOUD_SAAS
NODE_ENV=production

APP_PUBLIC_PORT=80
CORS_ORIGINS=http://localhost
BUSINESS_TIMEZONE=UTC
TENANT_ID=replace-me-tenant-id
ACCOUNT_ID=replace-me-account-id

DATABASE_HOST=your-hosted-db-host
DATABASE_PORT=5432
DATABASE_NAME=zsdb
DATABASE_USER=zs
DATABASE_PASSWORD=change-me-db-password
DATABASE_SCHEMA=public
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=true
DATABASE_SSL_CA_CERT=

ENABLE_BOOTSTRAP_ADMIN=false
DEFAULT_ADMIN_USERNAME=
DEFAULT_ADMIN_PASSWORD=

SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAME_SITE=strict
SESSION_CSRF_SECRET=replace-me-with-long-random-secret
