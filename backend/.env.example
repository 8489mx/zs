# Shared baseline example (safe placeholders only)
NODE_ENV=development
APP_MODE=LOCAL_PILOT
APP_HOST=0.0.0.0
PORT=3001
APP_PORT=3001

DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_NAME=zs_app
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=false

PLATFORM_TENANT_ID=default
TENANT_ID=default
ACCOUNT_ID=default

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

SESSION_COOKIE_NAME=zs_session
SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAME_SITE=lax
SESSION_CSRF_SECRET=CHANGE_ME_WITH_A_LONG_RANDOM_SECRET
ALLOW_SESSION_ID_HEADER=false

ENABLE_BOOTSTRAP_ADMIN=false
ALLOW_BOOTSTRAP_ADMIN_IN_PRODUCTION=false
DEFAULT_ADMIN_USERNAME=
DEFAULT_ADMIN_PASSWORD=

LOGIN_RATE_LIMIT_MAX=10
LOGIN_RATE_LIMIT_WINDOW_SECONDS=600
AUTH_BURST_RATE_LIMIT_MAX=60
AUTH_BURST_RATE_LIMIT_WINDOW_SECONDS=60

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM_NAME=Z Systems
MAIL_FROM_EMAIL=no-reply@example.com
APP_LOGIN_URL=http://localhost:5173/login
MAIL_DELIVERY_MODE=console
PUBLIC_TRIAL_DEBUG_CREDENTIALS=false
