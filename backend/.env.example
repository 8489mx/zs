NODE_ENV=development
APP_MODE=online
APP_HOST=0.0.0.0
APP_PORT=3001
LOG_LEVEL=info

DATABASE_HOST=your-db-host
DATABASE_PORT=5432
DATABASE_NAME=your-db-name
DATABASE_USER=your-db-user
DATABASE_PASSWORD=your-db-password
DATABASE_SCHEMA=public
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=true
DATABASE_SSL_CA_CERT=
DATABASE_LOGGING=false

ENABLE_BOOTSTRAP_ADMIN=false
ACTIVATION_ENFORCED=false
ACTIVATION_PUBLIC_KEY=
ALLOW_BOOTSTRAP_ADMIN_IN_PRODUCTION=false
DEFAULT_ADMIN_USERNAME=
DEFAULT_ADMIN_PASSWORD=
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAME_SITE=lax
SESSION_CSRF_SECRET=replace-with-a-long-random-secret
ALLOW_SESSION_ID_HEADER=false
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

LOGIN_RATE_LIMIT_MAX=10
LOGIN_RATE_LIMIT_WINDOW_SECONDS=600
AUTH_BURST_RATE_LIMIT_MAX=60
AUTH_BURST_RATE_LIMIT_WINDOW_SECONDS=60

BUSINESS_TIMEZONE=UTC
