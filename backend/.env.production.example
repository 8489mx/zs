NODE_ENV=production
APP_HOST=0.0.0.0
APP_PORT=3001
LOG_LEVEL=info

DATABASE_HOST=replace-me
DATABASE_PORT=5432
DATABASE_NAME=replace-me
DATABASE_USER=replace-me
DATABASE_PASSWORD=replace-me
DATABASE_SCHEMA=public
DATABASE_SSL=true
DATABASE_LOGGING=false

ENABLE_BOOTSTRAP_ADMIN=false
ACTIVATION_ENFORCED=false
ACTIVATION_PUBLIC_KEY=
ALLOW_BOOTSTRAP_ADMIN_IN_PRODUCTION=false
DEFAULT_ADMIN_USERNAME=
DEFAULT_ADMIN_PASSWORD=
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAME_SITE=strict
SESSION_CSRF_SECRET=replace-with-long-random-secret
ALLOW_SESSION_ID_HEADER=false
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
CORS_ORIGINS=https://your-frontend.example.com

LOGIN_RATE_LIMIT_MAX=10
LOGIN_RATE_LIMIT_WINDOW_SECONDS=600
AUTH_BURST_RATE_LIMIT_MAX=60
AUTH_BURST_RATE_LIMIT_WINDOW_SECONDS=60

BUSINESS_TIMEZONE=Africa/Cairo
