NODE_ENV=production
APP_MODE=CLOUD_SAAS
PORT=3001
APP_PORT=3001

DATABASE_HOST=<production-db-host>
DATABASE_PORT=5432
DATABASE_NAME=<production-db-name>
DATABASE_USER=<production-db-user>
DATABASE_PASSWORD=<production-db-password>
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=true

PLATFORM_TENANT_ID=<real-platform-tenant-id>
TENANT_ID=default
ACCOUNT_ID=default

CORS_ORIGINS=https://<your-frontend-domain>

SESSION_COOKIE_NAME=zs_session
SESSION_COOKIE_DOMAIN=.<your-domain>
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAME_SITE=strict

SMTP_HOST=<smtp-host>
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=<smtp-user>
SMTP_PASSWORD=<smtp-password>
MAIL_FROM_NAME=<from-name>
MAIL_FROM_EMAIL=<from-email>
APP_LOGIN_URL=https://<your-frontend-domain>/login
MAIL_DELIVERY_MODE=smtp
PUBLIC_TRIAL_DEBUG_CREDENTIALS=false
ENABLE_BOOTSTRAP_ADMIN=false
ALLOW_BOOTSTRAP_ADMIN_IN_PRODUCTION=false
ALLOW_SESSION_ID_HEADER=false
