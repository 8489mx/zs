NODE_ENV=development
APP_MODE=LOCAL_PILOT
APP_HOST=0.0.0.0
APP_PORT=3101
LOG_LEVEL=info

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=zs_dev
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_SCHEMA=public
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=false
DATABASE_LOGGING=false

ENABLE_BOOTSTRAP_ADMIN=true
DEFAULT_ADMIN_USERNAME=dev
DEFAULT_ADMIN_PASSWORD=1

SESSION_COOKIE_NAME=zs_dev_session
SESSION_CSRF_COOKIE_NAME=zs_dev_csrf_token
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAME_SITE=lax
SESSION_CSRF_SECRET=zs-dev-csrf-secret-change-me
ALLOW_SESSION_ID_HEADER=false

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

