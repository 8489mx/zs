# Z Systems - Cloud SaaS Backend Environment Example
# Copy this file to backend/.env for local maintenance scripts or import it into Hostinger.
# Keep real secrets out of GitHub. Replace every CHANGE_ME value before use.

NODE_ENV=production
APP_MODE=CLOUD_SAAS
APP_HOST=0.0.0.0
APP_PORT=3001
LOG_LEVEL=info

# Supabase / hosted PostgreSQL
DATABASE_HOST=CHANGE_ME_SUPABASE_POOLER_HOST
DATABASE_PORT=5432
DATABASE_NAME=postgres
DATABASE_USER=CHANGE_ME_SUPABASE_DATABASE_USER
DATABASE_PASSWORD=CHANGE_ME_SUPABASE_DATABASE_PASSWORD
DATABASE_SCHEMA=public
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=true
DATABASE_SSL_CA_CERT_B64=CHANGE_ME_SUPABASE_CA_CERT_BASE64
DATABASE_LOGGING=false

# Session / CSRF
SESSION_COOKIE_NAME=zs_cloud_session
SESSION_CSRF_COOKIE_NAME=zs_cloud_csrf_token
SESSION_COOKIE_DOMAIN=.CHANGE_ME_ROOT_DOMAIN
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAME_SITE=lax
SESSION_CSRF_SECRET=CHANGE_ME_LONG_RANDOM_SECRET_32_CHARS_OR_MORE
ALLOW_SESSION_ID_HEADER=false

# Tenant/account scope
TENANT_ID=CHANGE_ME_TENANT_ID
ACCOUNT_ID=CHANGE_ME_ACCOUNT_ID

# Frontend URL allowed to call the API
CORS_ORIGINS=https://app.CHANGE_ME_ROOT_DOMAIN

# Bootstrap admin is for first launch only.
# Keep disabled after the first super admin/emergency account is created and verified.
ENABLE_BOOTSTRAP_ADMIN=false
ALLOW_BOOTSTRAP_ADMIN_IN_PRODUCTION=false
DEFAULT_ADMIN_USERNAME=
DEFAULT_ADMIN_PASSWORD=

# Emergency super admin reference only.
# Do not put the real password in GitHub. Create/reset it with:
# node backend/scripts/reset-zs-password.js --support-only=true --username=superadmin --password="CHANGE_ME_STRONG_PASSWORD_14_PLUS_CHARS" --display-name="Emergency Super Admin"
EMERGENCY_SUPER_ADMIN_USERNAME=superadmin
EMERGENCY_SUPER_ADMIN_DISPLAY_NAME=Emergency Super Admin

# Security/rate limits
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
LOGIN_RATE_LIMIT_MAX=10
LOGIN_RATE_LIMIT_WINDOW_SECONDS=600
AUTH_BURST_RATE_LIMIT_MAX=60
AUTH_BURST_RATE_LIMIT_WINDOW_SECONDS=60

BUSINESS_TIMEZONE=Africa/Cairo
LICENSE_MODE=server
ACTIVATION_ENFORCED=false

# Hostinger build/runtime helpers
ZS_DEPLOY_TARGET=hostinger-api
NPM_CONFIG_PRODUCTION=false
NPM_CONFIG_INCLUDE=dev
