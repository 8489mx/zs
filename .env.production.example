# Z Systems POS production environment template
# Copy this file to .env.production ONLY on the production machine.
# Never commit the real .env.production file to source control.

NODE_ENV=production
HOST=0.0.0.0
PORT=3000
DB_FILE=data/zstore.db

# Generate with: npm run env:secret
SESSION_SECRET=replace-with-64-char-random-secret

# Comma-separated HTTPS origins allowed to call the app.
# Example: https://pos.example.com,https://admin.example.com
ALLOWED_ORIGINS=https://replace-with-your-production-domain.example

COOKIE_SECURE=true
ENFORCE_SAME_ORIGIN_WRITES=true
TRUST_PROXY=1
REQUEST_LOGGING=true
LOG_LEVEL=info
LOG_FORMAT=plain
HEALTH_EXPOSE_DETAILS=false

# Production safety flags
ALLOW_RESET_USERS=false
ALLOW_RESTORE_USERS=false
ALLOW_LEGACY_STATE_WRITE=false
USE_LEGACY_FRONTEND_FALLBACK=false
SINGLE_STORE_MODE=true

# First-boot admin setup
DEFAULT_ADMIN_USERNAME=ZS
DEFAULT_ADMIN_PASSWORD=
MIN_ADMIN_PASSWORD_LENGTH=10

# Session / auth policy
SESSION_DAYS=7
MAX_FAILED_LOGIN_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15

# Operational tuning
SUPPORT_SNAPSHOT_LIMIT=20
STORE_NAME=Z Systems
