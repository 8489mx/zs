{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "description": "Phase 1 NestJS backend scaffold for POS migration",
  "scripts": {
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "build": "nest build",
    "typecheck": "tsc --noEmit",
    "test:smoke": "ts-node test/smoke.ts",
    "migration:run": "ts-node src/database/migrate.ts up",
    "migration:revert": "ts-node src/database/migrate.ts down",
    "migration:list": "ts-node src/database/migrate.ts list",
    "migration:phase5": "ts-node src/migration/index.ts",
    "test:infra": "ts-node test/infra/permission.service.spec.ts && ts-node test/infra/error.mapper.spec.ts && ts-node test/infra/sales.phase4e.dto.spec.ts && ts-node test/infra/purchases.phase4f.dto.spec.ts && ts-node test/infra/reports.phase4g.dto.spec.ts && npm run test:critical",
    "test:critical": "ts-node test/critical/financial-integrity.spec.ts && ts-node test/critical/return-payload.spec.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.0",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.0",
    "@nestjs/platform-express": "^11.1.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "dotenv": "^16.4.5",
    "kysely": "^0.28.8",
    "pg": "^8.16.3",
    "pino": "^9.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.10",
    "@nestjs/schematics": "^11.0.4",
    "@nestjs/testing": "^11.1.0",
    "@types/express": "^5.0.4",
    "@types/node": "^24.9.1",
    "@types/pg": "^8.15.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}