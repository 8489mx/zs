[Unit]
Description=Z Systems application service
After=network.target

[Service]
Type=simple
User=zsystems
Group=zsystems
WorkingDirectory=/opt/zsystems/current
EnvironmentFile=/etc/zsystems/zsystems.env
ExecStartPre=/usr/bin/npm run verify:production:startup
ExecStart=/usr/bin/npm run start:prod:safe
Restart=always
RestartSec=5
TimeoutStartSec=120
TimeoutStopSec=30
KillSignal=SIGINT
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/opt/zsystems/current/data /opt/zsystems/current/logs

[Install]
WantedBy=multi-user.target
