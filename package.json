{
  "name": "zs-main",
  "private": true,
  "version": "1.1.0",
  "scripts": {
    "install:all": "npm --prefix backend ci && npm --prefix frontend ci",
    "build": "npm --prefix backend run build && npm --prefix frontend run build",
    "qa": "npm --prefix backend run check:commercial-ready && npm --prefix frontend run qa",
    "qa:backend": "npm --prefix backend run check:commercial-ready",
    "qa:frontend": "npm --prefix frontend run qa",
    "lint": "npm --prefix frontend run lint",
    "typecheck": "npm --prefix backend run typecheck",
    "test:critical": "npm --prefix backend run test:critical",
    "e2e:backend": "npm --prefix backend run test:e2e",
    "compose:up": "docker compose up --build -d",
    "compose:down": "docker compose down",
    "compose:logs": "docker compose logs -f --tail=200",
    "compose:prod:up": "docker compose -f docker-compose.prod.yml up --build -d",
    "compose:prod:down": "docker compose -f docker-compose.prod.yml down",
    "compose:prod:logs": "docker compose -f docker-compose.prod.yml logs -f --tail=200",
    "compose:prod:config": "docker compose -f docker-compose.prod.yml config",
    "compose:offline:up": "docker compose --env-file .env.offline -f docker-compose.offline.yml up --build -d",
    "compose:offline:down": "docker compose --env-file .env.offline -f docker-compose.offline.yml down",
    "compose:offline:logs": "docker compose --env-file .env.offline -f docker-compose.offline.yml logs -f --tail=200",
    "compose:offline:config": "docker compose --env-file .env.offline -f docker-compose.offline.yml config",
    "offline:install": "bash ./scripts/offline/install.sh",
    "offline:start": "bash ./scripts/offline/start.sh",
    "offline:stop": "bash ./scripts/offline/stop.sh",
    "offline:backup": "bash ./scripts/offline/backup.sh",
    "offline:restore": "bash ./scripts/offline/restore.sh",
    "offline:upgrade": "bash ./scripts/offline/upgrade.sh",
    "offline:rollback": "bash ./scripts/offline/rollback.sh",
    "audit:offline-independence": "bash ./scripts/audit/check-offline-independence.sh",
    "audit:offline-signoff": "bash ./scripts/audit/create-offline-signoff.sh",
    "audit:launch-report": "bash ./scripts/audit/generate-launch-readiness-report.sh",
    "release:bundle": "bash ./scripts/release/create-release-bundle.sh",
    "release:verify": "bash ./scripts/release/verify-release-bundle.sh",
    "installer:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File ./installer/windows/build-installer.ps1",
    "compose:e2e": "docker compose up -d postgres backend && bash ./scripts/wait-for-http.sh http://127.0.0.1:3001/health 90 2 && npm --prefix backend run test:e2e",
    "dev:backend": "npm --prefix backend run start:dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "qa:release": "npm run qa && npm run compose:e2e && npm run package:clean",
    "e2e:self": "bash ./scripts/run-backend-e2e-local.sh",
    "package:clean": "bash ./scripts/package-clean-release.sh",
    "qa:sale-ready": "bash ./scripts/certify-sale-ready.sh",
    "qa:toolchain": "node ./scripts/check-toolchain-alignment.cjs"
  },
  "engines": {
    "node": ">=22 <23",
    "npm": ">=10 <11"
  }
}
