{
  "name": "z-systems-pos-v6",
  "version": "6.0.0",
  "description": "Z Systems Product Polish Core v6",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "npm run frontend:build && npm run start:server",
    "dev": "node src/server.js",
    "reset-db": "node reset-database.js",
    "admin:reset-password": "node scripts/reset-admin-password.js",
    "test": "npm run qa:architecture && node tests/run-tests.js && node tests/import-routes-tests.js && node tests/branch-location-routes-tests.js && npm run test:integration && npm run test:demo-data && npm run test:pilot",
    "smoke-test": "node tests/smoke-tests.js",
    "test:integration": "node tests/integration-tests.js",
    "syntax:check": "node --check src/server.js && node --check src/backup-service.js && node --check src/launch-gate.js && node --check src/system-routes.js && node --check tests/run-tests.js && node --check tests/integration-tests.js",
    "launch:gate": "node scripts/launch-gate.js",
    "verify:runtime": "node scripts/final-runtime-verify.js",
    "launch:gate:prod": "LAUNCH_GATE_ENV=production node scripts/launch-gate.js --production-env-file .env.production",
    "frontend:dev": "npm --prefix frontend run dev",
    "frontend:build": "npm --prefix frontend run build",
    "frontend:preview": "npm --prefix frontend run preview",
    "frontend:qa": "npm --prefix frontend run qa",
    "frontend:qa:functional": "npm --prefix frontend run qa:functional",
    "frontend:qa:phase13": "npm --prefix frontend run qa:phase13",
    "frontend:qa:api": "npm --prefix frontend run qa:api",
    "frontend:qa:phase14": "npm --prefix frontend run qa:phase14",
    "frontend:qa:phase15": "npm --prefix frontend run qa:phase15",
    "frontend:qa:phase16": "npm --prefix frontend run qa:phase16",
    "frontend:qa:phase17": "npm --prefix frontend run qa:phase17",
    "frontend:qa:phase18": "npm --prefix frontend run qa:phase18",
    "frontend:qa:phase19": "npm --prefix frontend run qa:phase19",
    "frontend:qa:phase20": "npm --prefix frontend run qa:phase20",
    "frontend:qa:phase21": "npm --prefix frontend run qa:phase21",
    "frontend:qa:phase22": "npm --prefix frontend run qa:phase22",
    "frontend:qa:phase23": "npm --prefix frontend run qa:phase23",
    "audit:release": "node scripts/release-audit.js",
    "frontend:qa:release": "npm --prefix frontend run qa:release",
    "postinstall": "npm --prefix frontend install",
    "start:server": "node src/server.js",
    "frontend:qa:phase57": "npm --prefix frontend run qa:phase57",
    "frontend:qa:phase58": "npm --prefix frontend run qa:phase58",
    "frontend:qa:phase59": "npm --prefix frontend run qa:phase59",
    "regression:final": "node scripts/final-regression-pass.js",
    "audit:release:strict": "RELEASE_AUDIT_STRICT=true node scripts/release-audit.js",
    "frontend:qa:phase60": "npm --prefix frontend run qa:phase60",
    "release:closeout": "node scripts/strict-release-closeout.js",
    "cutover:pack": "node scripts/generate-cutover-pack.js",
    "verify:post-launch": "node scripts/post-launch-verification.js",
    "cutover:validate": "node scripts/validate-cutover-status.js",
    "release:ready": "node scripts/release-readiness-check.js",
    "release:artifact": "node scripts/build-release-artifact.js",
    "release:artifact:check": "node scripts/release-artifact-check.js",
    "source:clean": "npm run handoff:source && node scripts/verify-source-handoff.js",
    "env:secret": "node scripts/generate-session-secret.js",
    "env:production:check": "node scripts/production-env-check.js",
    "env:production:check:strict": "node scripts/production-env-check.js --strict",
    "verify:production:startup": "node scripts/production-startup-check.js",
    "start:prod:safe": "npm run frontend:build && npm run verify:production:startup && NODE_ENV=production node src/server.js",
    "go-live:checklist": "npm run release:closeout && npm run release:artifact && npm run release:artifact:check && npm run env:production:check && npm run verify:production:startup && npm run deploy:target:check",
    "deploy:target:check": "node scripts/deployment-target-check.js",
    "handoff:source": "node scripts/build-source-handoff.js",
    "seed:demo": "node scripts/seed-demo.js --fresh --force",
    "reset:demo": "node scripts/reset-demo.js",
    "test:demo-data": "node tests/demo-data-pack-tests.js",
    "test:pilot": "node tests/pilot-smoke-tests.js",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "qa:architecture": "node scripts/architecture-file-size-check.js && node scripts/backend-import-boundary-check.js && npm --prefix frontend run qa:architecture",
    "lint": "node ./node_modules/eslint/bin/eslint.js .",
    "lint:fix": "node ./node_modules/eslint/bin/eslint.js . --fix",
    "qa:quality": "npm run lint && npm --prefix frontend run lint && npm run qa:architecture",
    "production:drill": "node scripts/production-readiness-drill.js",
    "backup:drill": "node scripts/backup-restore-drill.js",
    "go-live:pilot": "npm run production:drill && npm run source:clean && npm run backup:drill"
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "express": "^4.22.1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "overrides": {
    "path-to-regexp": "0.1.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.0",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^17.4.0"
  }
}
